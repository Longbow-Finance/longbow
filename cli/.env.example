# Copy to .env and fill in after the contracts are deployed.
# NOTHING here is secret except a private key, which you should NOT put in a
# committed file. Prefer entering the key at the masked prompt instead.

LONGBOW_POSITION_MANAGER=0x0000000000000000000000000000000000000000
LONGBOW_LONG_TOKEN=0x0000000000000000000000000000000000000000
LONGBOW_ORACLE=0x0000000000000000000000000000000000000000

# Public RPC endpoint (defaults to the Robinhood Chain public RPC).
LONGBOW_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# OPTIONAL and OPTIONAL ONLY. If set, the CLI will use this key for signing
# instead of prompting. It stays on your machine. Never commit a real key.
# LONGBOW_PRIVATE_KEY=
