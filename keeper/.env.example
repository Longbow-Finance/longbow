# Longbow keeper configuration. Copy to `.env` and fill in.

# Keeper account private key (receives liquidation bounties). Keep this secret.
PRIVATE_KEY=0x...

# Deployed contract addresses (from the Deploy script output).
POSITION_MANAGER=0x...
ORACLE=0x...

# Optional overrides (defaults shown).
RPC_URL=https://rpc.mainnet.chain.robinhood.com
CHAIN_ID=4663
POLL_INTERVAL_MS=60000
